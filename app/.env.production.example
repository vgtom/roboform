# Copy this file to `.env.production` before running `wasp deploy fly deploy`
# so the browser calls your Fly server API (required when the client is on a custom domain
# like https://vinforms.com and the API stays on https://vinforms-app-server.fly.dev).
#
# If you later put the API behind https://api.vinforms.com, update this URL accordingly.

REACT_APP_API_URL=https://vinforms-app-server.fly.dev
